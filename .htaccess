<IfModule mod_headers.c>
    # Unset strict headers that might be inherited
    Header unset Content-Security-Policy
    Header always unset Content-Security-Policy
    
    # Set permissive policy
    Header set Content-Security-Policy "default-src * 'unsafe-inline' 'unsafe-eval' data: blob:; script-src * 'unsafe-inline' 'unsafe-eval'; connect-src * 'unsafe-inline'; img-src * data: blob: 'unsafe-inline'; frame-src *; style-src * 'unsafe-inline';"
    Header set Access-Control-Allow-Origin "*"
</IfModule>
